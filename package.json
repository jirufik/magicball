{
  "name": "magicball",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --watch src/server --ext ts --exec \"npm run server:build && node dist/server/bin/www.js\"",
    "server:build": "tsc -p tsconfig.server.json",
    "client:dev": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node ./dist/server/bin/www.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "debug": "^4.3.7",
    "express": "^4.21.0",
    "morgan": "^1.10.0",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/cookie-parser": "^1.4.7",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "phaser": "^3.80.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
